{
    "name": "basic_handshake",
    "description": "TLS handshake completion and connection establishment",
    "peer_requirements": {
        "binary": "ngtcp2",
        "min_version": "0.9.0"
    },
    "flowq_requirements": {
        "tls_backend": "provider-backed",
        "min_version": "0.1.0"
    },
    "steps": [
        {
            "action": "client_send_initial",
            "expect": "server_initial_response"
        },
        {
            "action": "exchange_handshake",
            "expect": "handshake_confirmed"
        }
    ],
    "timeout_ms": 5000,
    "skip_if_missing": ["peer_binary", "tls_backend"]
}
